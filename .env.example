# ===== Provider Selection =====
# Choose embedding provider: openai, gemini
EMBEDDING_PROVIDER=openai

# ===== Provider API Keys =====
# OpenAI API key (required for openai provider)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API key (required for gemini provider) 
GEMINI_API_KEY=your_gemini_api_key_here

# ===== Provider-Specific Models =====
# OpenAI embedding models
OPENAI_DEFAULT_MODEL=text-embedding-3-small
OPENAI_TIMEOUT=30.0

# Gemini embedding models
GEMINI_DEFAULT_MODEL=models/embedding-001
GEMINI_TIMEOUT=30.0

# ===== Vector Database Configuration =====
# Chroma database settings
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=documents

# ===== Search Configuration =====
# Default search parameters
DEFAULT_SEARCH_RESULTS=5
MAX_SEARCH_RESULTS=50
SIMILARITY_THRESHOLD=0.0

# ===== Document Processing =====
# Text chunking settings
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200
BATCH_SIZE=10

# ===== Application Settings =====
APP_NAME=Semantic Search API
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ===== API Configuration =====
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]
MAX_RETRIES=3
REQUEST_TIMEOUT=300.0

# ===== Development Settings =====
# Mock mode for testing without API keys
USE_MOCK_EMBEDDINGS=false
MOCK_EMBEDDING_DIMENSION=1536